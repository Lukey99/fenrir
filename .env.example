# Copy this file to `.env` and fill in real values.
# `.env` is gitignored and must never be committed.

# PostgreSQL connection string, used by the app at runtime.
# Local dev (docker-compose): postgresql://gym_tracker:gym_tracker@localhost:55432/gym_tracker
# (port 55432, not 5432 — avoids clashing with any native Postgres install on your machine)
# Production (Neon/Supabase): the POOLED connection string from your provider's dashboard
# (Supabase: "Transaction pooler", port 6543) — serverless functions open lots of short-lived
# connections, and the pooler avoids exhausting Postgres' connection limit.
DATABASE_URL="postgresql://gym_tracker:gym_tracker@localhost:55432/gym_tracker"

# Direct (non-pooled) connection string, used only by `prisma migrate deploy` at build time.
# Optional locally (falls back to DATABASE_URL, which is already a direct connection there).
# Required in production: pgbouncer's transaction-mode pooling doesn't support the advisory
# lock Prisma Migrate needs, so running migrations over DATABASE_URL (pooled) can hang forever.
# Production (Supabase): the "Direct connection" string, port 5432.
DIRECT_URL=""

# Auth.js (NextAuth v5) secret used to sign/encrypt session tokens.
# Generate one with: npx auth secret
AUTH_SECRET=""
